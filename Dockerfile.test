# fs-mcp Multi-Arch Dependency Test
# Tests that all dependencies install correctly on fresh systems.
# Supports: linux/amd64, linux/arm64 (Pi/ARM)
#
# Usage:
#   docker build -t fs-mcp-test -f Dockerfile.test .
#   docker buildx build --platform linux/amd64,linux/arm64 -f Dockerfile.test .

FROM python:3.10-slim AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates bash git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# --- Stage 1: Install CLI dependencies ---
FROM base AS deps

# ripgrep + jq — available in apt for all Debian archs
RUN apt-get update && apt-get install -y --no-install-recommends ripgrep jq \
    && rm -rf /var/lib/apt/lists/* \
    && echo "rg: $(rg --version | head -1)" \
    && echo "jq: $(jq --version)"

# yq — official binaries for amd64 + arm64
RUN ARCH=$(dpkg --print-architecture) && \
    YQ_ARCH=$([ "$ARCH" = "amd64" ] && echo "amd64" || echo "arm64") && \
    curl -fsSL "https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${YQ_ARCH}" -o /usr/local/bin/yq && \
    chmod +x /usr/local/bin/yq && \
    echo "yq: $(yq --version)"

# RTK — may not have ARM binary (graceful failure expected on arm64)
RUN curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh 2>&1; \
    if [ -f "$HOME/.local/bin/rtk" ]; then \
        echo "rtk: $($HOME/.local/bin/rtk --version) [OK]"; \
    else \
        echo "rtk: NOT AVAILABLE for $(uname -m) [EXPECTED ON ARM]"; \
    fi

# --- Stage 2: Install fs-mcp and test ---
FROM deps AS test

COPY . /app/
ENV PATH="$PATH:/root/.local/bin"

# Install fs-mcp
RUN pip install --no-cache-dir uv 2>/dev/null && \
    uv pip install --system -e "." 2>/dev/null || pip install --no-cache-dir -e "."

# Dependency check (should not exit(1) even without RTK)
COPY scripts/docker-dep-check.py /tmp/dep-check.py
RUN python /tmp/dep-check.py

# Run tests
RUN python -m pytest tests/test_rtk_integration.py tests/test_rtk_new_integration.py tests/test_check_deps.py -v --tb=short 2>&1; \
    echo "Tests exit code: $?"

CMD ["echo", "fs-mcp dependency tests complete"]
